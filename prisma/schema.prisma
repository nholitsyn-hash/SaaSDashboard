// SaaS Analytics Dashboard — Prisma Schema
//
// Models:
//   User, Organization, Membership (multi-org with roles)
//   Account, Session, VerificationToken (Auth.js adapter requirements)
//
// WHY @@map("snake_case"):
//   PostgreSQL convention is snake_case table names.
//   Prisma models are PascalCase. @@map bridges the two
//   so the DB is clean and the code is idiomatic.
//
// WHY cuid() for IDs:
//   Collision-resistant, URL-safe, sortable-ish.
//   Better than UUID for URLs, better than autoincrement
//   for distributed systems like Neon serverless.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  super_admin
  admin
  viewer
}

/// WHY values mirror our TypeScript mock unions exactly:
///   Prisma enums generate a Postgres ENUM type AND a matching TS literal
///   union. Keeping Prisma member names === mock string values means the
///   API boundary stays zero-translation — no mapping layer needed.
enum CustomerPlan {
  Free
  Pro
  Enterprise
}

enum CustomerStatus {
  active
  trial
  churned
}

enum SubPlan {
  Pro
  Enterprise
}

enum SubStatus {
  active
  trial
  paused
  canceled
}

enum BillingCycle {
  monthly
  annual
}

enum SignupState {
  pending
  approved
  rejected
}

enum InviteStatus {
  pending
  accepted
  revoked
  expired
}

enum IntegrationStatus {
  connected
  available
}

enum IntegrationCategory {
  Payments
  CRM
  Communication
  Analytics
  Automation
}

enum CardBrand {
  Visa
  Mastercard
  Amex
}

enum InvoiceStatus {
  paid
  failed
  upcoming
}

// ---------------------------------------------------------------------------
// Core business models
// ---------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String?
  image         String?
  emailVerified DateTime?
  /// Most-recent activity timestamp.
  /// In production, bumped on session refresh / API hit. For mock data we
  /// seed values that produce realistic "Active now / 2 hours ago" labels.
  lastActiveAt  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  memberships     Membership[]
  accounts        Account[]
  sessions        Session[]
  sentInvitations Invitation[] @relation("InvitationSender")

  @@map("users")
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships    Membership[]
  customers      Customer[]
  signupRequests SignupRequest[]
  invitations    Invitation[]
  integrations   Integration[]
  workspaceSub   WorkspaceSubscription?

  @@map("organizations")
}

/// The workspace's subscription to OUR SaaS (distinct from `Subscription`,
/// which is OUR customers' subscriptions to the workspace).
///
/// WHY one row per Organization (`organizationId @unique`):
///   An org has exactly one active billing arrangement at a time. Plan
///   changes mutate the row; downgrades/upgrades aren't separate records.
///   Historical plan changes belong in a separate audit table when needed.
///
/// WHY usage stored on this row (not a separate UsageSnapshot table):
///   Mock-data simplicity. In production, usage is metered and changes
///   constantly — would belong in a time-series table. Comment here so
///   future-me doesn't think this is the right design at scale.
///
/// WHY payment method denormalized (not its own model):
///   Real cards live in Stripe — we only cache `last4 + brand + exp` for
///   display. No PII / no PCI scope. One row reused per workspace.
model WorkspaceSubscription {
  id                String       @id @default(cuid())
  organizationId    String       @unique
  planName          String
  planTier          CustomerPlan
  priceMonthlyCents Int
  cycle             BillingCycle
  nextBillAt        DateTime
  renewsAt          DateTime
  // Plan limits
  eventsLimit       Int
  seatsLimit        Int
  storageLimitGb    Float
  // Current usage
  eventsUsed        Int          @default(0)
  seatsUsed         Int          @default(0)
  storageUsedGb     Float        @default(0)
  // Cached payment method (real card lives in Stripe)
  cardBrand         CardBrand?
  cardLast4         String?
  cardExpMonth      Int?
  cardExpYear       Int?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoices     Invoice[]

  @@map("workspace_subscriptions")
}

model Invoice {
  id             String        @id @default(cuid())
  workspaceSubId String
  number         String        @unique
  date           DateTime
  amountCents    Int
  status         InvoiceStatus

  workspaceSub WorkspaceSubscription @relation(fields: [workspaceSubId], references: [id], onDelete: Cascade)

  @@index([workspaceSubId, date])
  @@map("invoices")
}

/// A workspace's view of a third-party integration.
///
/// WHY one row per (org × integration), not two tables (catalog + connection):
///   In production the catalog is rarely-changing, central data; connections
///   are per-org with credentials and webhooks. For a portfolio mock that
///   distinction adds boilerplate without UX value. One table = one row per
///   "integration card" the org sees, with `status` flipping the badge.
///   Refactor to two tables when we wire real OAuth flows.
model Integration {
  id             String              @id @default(cuid())
  organizationId String
  slug           String
  name           String
  category       IntegrationCategory
  description    String
  status         IntegrationStatus   @default(available)
  connectedAt    DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, slug])
  @@index([organizationId, status])
  @@map("integrations")
}

/// Workspace invitation — pending until accepted or revoked.
///
/// WHY separate from User:
///   Invitees don't have user accounts yet. Storing them here keeps auth
///   tables free of pre-account rows and makes "resend" / "revoke" a
///   one-row mutation.
///
/// WHY @@unique([organizationId, email]):
///   Same email can't have two open invitations to the same org.
///   The same email CAN have invitations to different orgs.
model Invitation {
  id             String       @id @default(cuid())
  organizationId String
  email          String
  role           Role         @default(viewer)
  status         InviteStatus @default(pending)
  invitedById    String
  createdAt      DateTime     @default(now())
  expiresAt      DateTime
  acceptedAt     DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy    User         @relation("InvitationSender", fields: [invitedById], references: [id], onDelete: Cascade)

  @@unique([organizationId, email])
  @@index([organizationId, status])
  @@map("invitations")
}

/// Inbound signup awaiting admin review.
///
/// WHY separate from User:
///   A User row exists only AFTER approval — we don't want pre-approval
///   signups to clutter the auth table with accounts that can't log in.
///   Keeping unapproved requests in their own table mirrors real SaaS
///   admin flows and makes role-based filtering trivial.
///
/// WHY reuse CustomerPlan (not a new enum):
///   The requested plan is the same vocabulary (Free/Pro/Enterprise) a
///   real Customer ends up with. Separate enums would drift and force
///   translation code.
model SignupRequest {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  email          String
  company        String
  requestedPlan  CustomerPlan
  state          SignupState  @default(pending)
  signedUpAt     DateTime
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, state])
  @@map("signup_requests")
}

/// A customer account owned by an Organization.
///
/// WHY `mrrCents: Int` (not Float dollars):
///   Money in floats causes $0.01 rounding bugs over time. Integer cents
///   is the industry standard. Our display layer divides by 100 before
///   formatting. Stripe uses cents too — when we wire real data later,
///   no conversion layer needed.
model Customer {
  id             String         @id @default(cuid())
  organizationId String
  company        String
  contact        String
  email          String
  plan           CustomerPlan
  status         CustomerStatus
  mrrCents       Int
  region         String
  joinedAt       DateTime
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscriptions Subscription[]

  @@index([organizationId, status])
  @@index([organizationId, plan])
  @@map("customers")
}

/// A billing subscription owned by a Customer.
///
/// WHY `renewsAt` is nullable:
///   Paused and canceled subscriptions have no next renewal date.
///   The UI renders "—" for null — cleaner than pretending a date exists.
///
/// WHY separate enums from Customer:
///   Customer.plan ("Free" | "Pro" | "Enterprise") and Subscription.plan
///   ("Pro" | "Enterprise") don't overlap — Free users don't have a paid
///   subscription. Keeping the enums separate reflects that constraint
///   at the type level.
model Subscription {
  id         String       @id @default(cuid())
  customerId String
  plan       SubPlan
  cycle      BillingCycle
  status     SubStatus
  mrrCents   Int
  startedAt  DateTime
  renewsAt   DateTime?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([status])
  @@map("subscriptions")
}

/// Join table: a User belongs to an Organization with a specific Role.
/// @@unique ensures one membership per user per org.
model Membership {
  id             String   @id @default(cuid())
  role           Role     @default(viewer)
  userId         String
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@map("memberships")
}

// ---------------------------------------------------------------------------
// Auth.js adapter models
//
// WHY these exist even though we start with Credentials:
//   The PrismaAdapter requires them. Account & Session tables enable
//   OAuth providers as a drop-in later (GitHub, Google, etc.).
//   VerificationToken supports email verification flows.
// ---------------------------------------------------------------------------

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}
